<?xml version="1.0" encoding="UTF-8"?>
<!-- Path: C:\inetpub\wwwroot\teknisk.hkbb.no\public\web.config -->
<configuration>
  <system.webServer>

    <!-- IIS 413 fix (maks request-størrelse i bytes) -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="524288000" />
      </requestFiltering>
    </security>

    <rewrite>
      <rules>

        <!-- 1) Ikke rør /uploads -->
        <rule name="SkipUploads" stopProcessing="true">
          <match url="^uploads(/.*)?$" />
          <action type="None" />
        </rule>

        <!-- 2) Ikke rewrite hvis det er en faktisk fil (gjelder også /lager/api/*.php) -->
        <rule name="SkipExistingFiles" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- 3) Ikke rewrite hvis det er en faktisk mappe -->
        <rule name="SkipExistingDirectories" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- 4) EKSTRA SIKKERHET: ikke route /lager/api/* til lager/index.php -->
        <rule name="SkipLagerApi" stopProcessing="true">
          <match url="^lager/api/.*$" />
          <action type="None" />
        </rule>

        <!-- 5) Route ALT under /lager til /lager/index.php (men nå etter "skip file/dir") -->
        <rule name="RouteLagerToLagerIndex" stopProcessing="true">
          <match url="^lager(/.*)?$" />
          <action type="Rewrite" url="lager/index.php" appendQueryString="true" />
        </rule>

        <!-- 6) Front controller for resten (kun når det ikke er fil/mappe) -->
        <rule name="FrontController" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.php" appendQueryString="true" />
        </rule>

      </rules>
    </rewrite>
  </system.webServer>
</configuration>