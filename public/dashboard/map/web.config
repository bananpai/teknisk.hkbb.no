<?xml version="1.0" encoding="UTF-8"?>
<!-- Path: /public/dashboard/map/web.config -->
<!-- TV-dashboard: fjern headers som blokkerer visning i nettleser/kiosk -->
<configuration>
  <system.webServer>
    <httpProtocol>
      <customHeaders>
        <remove name="X-Frame-Options" />
        <remove name="X-XSS-Protection" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
