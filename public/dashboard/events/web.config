<?xml version="1.0" encoding="UTF-8"?>
<!-- Path: /public/dashboard/events/web.config -->
<!-- TV-dashboard: fjern headers som blokkerer visning i nettleser/kiosk -->
<configuration>
  <system.webServer>
    <httpProtocol>
      <customHeaders>
        <!-- Fjern X-Frame-Options arvet fra /public/web.config slik at TV-dashbordet kan vises -->
        <remove name="X-Frame-Options" />
        <!-- Fjern X-XSS-Protection – utdatert og kan forstyrre noen TV-nettlesere -->
        <remove name="X-XSS-Protection" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
